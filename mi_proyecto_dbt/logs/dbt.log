    create  table
      "airbyte_curso"."main"."obt_pokemon_analysis__dbt_tmp"
  
    as (
      with pokemon as (
    select *
    from "airbyte_curso"."main"."int_pokemon_enriched"
),

latest_rates as (
    select distinct on (date)
        date,
        usd_rate,
        eur_rate,
        gbp_rate,
        jpy_rate
    from "airbyte_curso"."main"."stg_exchange_rates"
    order by date desc
    limit 1  -- usamos la tasa más reciente
)

select
    p.pokemon_id,
    p.pokemon_name,
    p.height,
    p.weight,
    p.base_experience,
    p.primary_type,
    p.num_types,
    p.weight_category,
    p.abilities,
    -- asignamos un precio hipotético en USD (ejemplo: 10 * base_experience)
    10 * p.base_experience as usd_price,
    -- convertimos a otras monedas usando las últimas tasas
    round(10 * p.base_experience * l.usd_rate, 2) as eur_price,
    round(10 * p.base_experience * l.gbp_rate, 2) as gbp_price,
    round(10 * p.base_experience * l.jpy_rate, 2) as jpy_price,
    l.date as exchange_rate_date
from pokemon p
cross join latest_rates l
    );
  
  
