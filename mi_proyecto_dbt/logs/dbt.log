    create  table
      "airbyte_curso"."main"."obt_pokemon_analysis__dbt_tmp"
  
    as (
      WITH pokemon AS (
    SELECT *
    FROM "airbyte_curso"."main"."int_pokemon_enriched"
),

latest_rates AS (
    SELECT
        date,
        usd_rate,
        eur_rate,
        gbp_rate,
        jpy_rate
    FROM "airbyte_curso"."main"."stg_exchange_rates"
    ORDER BY date DESC
    LIMIT 1   -- obtiene la fila más reciente
)

SELECT
    p.pokemon_id,
    p.pokemon_name,
    p.height,
    p.weight,
    p.base_experience,
    p.primary_type,
    p.num_types,
    p.weight_category,
    p.abilities,
    -- precio en USD (ejemplo: 10 * experiencia base)
    10 * p.base_experience AS usd_price,
    -- conversión a otras monedas usando las tasas más recientes
    ROUND(10 * p.base_experience * l.usd_rate, 2) AS eur_price,   -- nota: si usd_rate es USD/EUR, esto da EUR
    ROUND(10 * p.base_experience * l.gbp_rate, 2) AS gbp_price,
    ROUND(10 * p.base_experience * l.jpy_rate, 2) AS jpy_price,
    l.date AS exchange_rate_date
FROM pokemon p
CROSS JOIN latest_rates l
    );
  
  
