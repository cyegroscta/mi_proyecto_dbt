    -- One Big Table final para análisis
WITH pokemon AS (
SELECT

* FROM "airbyte_curso"."main"."int_pokemon_with_types"

),
final AS (
SELECT pokemon_id,
pokemon_name,
height,
weight,
base_experience,
type_primary,
type_secondary,
CASE
