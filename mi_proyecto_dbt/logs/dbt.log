    from "airbyte_curso"."main"."stg_pokemon"
),

-- Creamos una columna con el primer tipo para análisis (o concatenamos todos)
enriched as (
    select
        *,
        types[1] as primary_type,
        array_length(types) as num_types,
        -- categoría de peso según peso (kg)
        case
            when weight < 50 then 'light'
            when weight between 50 and 200 then 'medium'
            else 'heavy'
        end as weight_category
    from pokemon
)

select * from enriched
    );
  
  
